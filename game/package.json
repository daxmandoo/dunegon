{
    "scripts":  {
                    "start":  "electron .",
                    "pack":  "electron-builder --win --x64"
                },
    "description":  "Dunegon 3D Game",
    "version":  "1.0.0",
    "author":  "",
    "name":  "dunegon-3d",
    "main":  "electron.js",
    "build":  {
                  "appId":  "com.dunegon.game",
                  "productName":  "Dunegon 3D",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "index.html",
                                "style.css",
                                "main.js",
                                "electron.js",
                                "node_modules/**/*"
                            ],
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "portable",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ]
                          }
              },
    "devDependencies":  {
                            "electron":  "^41.2.1",
                            "electron-builder":  "^26.8.1"
                        },
    "license":  "ISC",
    "keywords":  [

                 ]
}